# Telegram backend settings (local proxy or Netlify function)
TELEGRAM_BOT_TOKEN=123456789:YOUR_BOT_TOKEN
TELEGRAM_CHAT_ID=123456789
TELEGRAM_PORT=8787

# Optional: override frontend endpoint for local proxy development.
# Leave empty on Netlify; frontend defaults to /telegram/send.
VITE_TELEGRAM_PROXY_URL=http://localhost:8787/telegram/send

# Optional: role -> chat_id map (JSON string)
# Use Telegram chat IDs for each role so alerts go to each phone/account.
VITE_TELEGRAM_ROLE_CHAT_IDS={"admin":"111111111","operation":"222222222","stock":"333333333","cutting":"444444444","qc":"555555555"}
